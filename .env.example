# Web administrator credentials (change before production use)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_strong_password
OPS_SSH_SECRET_KEY=change_me_to_another_long_random_secret

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_CHAT_ID=
TELEGRAM_BOT_USERNAME=king_detective_bot
TELEGRAM_STARTUP_DELAY_SECONDS=20

# Server
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=9527
CORS_ALLOWED_ORIGINS=*

# Release and automatic updates
KING_DETECTIVE_GITHUB_REPOSITORY=tony-wang1990/Wang-Detective-2
KING_DETECTIVE_GITHUB_BRANCH=main
KING_DETECTIVE_IMAGE=ghcr.io/tony-wang1990/wang-detective-2:main
KING_DETECTIVE_CLIENT_VERSION=0.1.0
CLIENT_DOWNLOAD_DIR=/app/king-detective/deploy/downloads

# Optional automation
AUTO_BACKUP_ENABLED=false
AUTO_BACKUP_CRON=0 0 3 * * ?
AUTO_BACKUP_PASSWORD=
INSTANCE_MONITOR_ENABLED=false
INSTANCE_MONITOR_INTERVAL_MS=300000

# Upload limits
SFTP_UPLOAD_MAX_FILE_SIZE=50MB
SFTP_UPLOAD_MAX_REQUEST_SIZE=50MB
